---
const {
  title = "Example Gift Guide",
  description = "Example description for a gift guide.",
  gifts = [
    {
      name: "Example Product 1",
      description: "This is an example product.",
      link: "https://amazon.com"
    },
    {
      name: "Example Product 2",
      description: "Another example product.",
      link: "https://amazon.com"
    }
  ]
} = Astro.props;
---

<html>
<head>
<title>{title}</title>
<meta name="description" content={description} />
</head>

<body>

<h1>{title}</h1>

<p>{description}</p>

<h2>Recommended Gifts</h2>

<ul>
{gifts.map((gift) => (
<li>
<h3>{gift.name}</h3>
<p>{gift.description}</p>

<a href={gift.link} target="_blank">
Check price on Amazon
</a>

</li>
))}
</ul>

</body>
</html>