---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides');
const featuredGuides = allGuides.slice(0, 3);
---

<BaseLayout
  title="Several Gifts"
  description="Thoughtful gift recommendations for emotional situations"
>
  <section class="hero">
    <div class="container">
      <h1>Thoughtful Gifts For Real Emotional Situations</h1>

      <p>
        Find meaningful gift ideas for relationships, difficult moments,
        emotional struggles, and life milestones.
      </p>

      <a href="/guides">Browse Gift Guides</a>
    </div>
  </section>

  <section class="featured">
    <div class="container">
      <h2>Featured Guides</h2>

      <div class="guides-grid">
        {featuredGuides.map((guide) => (
          <div class="guide-card">
            <h3>{guide.data.title}</h3>
            <p>{guide.data.description}</p>

            <a href={`/guides/${guide.slug}`}>
              Read Guide →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>