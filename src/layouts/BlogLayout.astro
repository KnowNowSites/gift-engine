---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  category?: string;
  publishDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description = '',
  image = '',
  category = '',
  publishDate,
  updatedDate
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
>
  <article class="blog-post">
    <div class="container">
      <header class="blog-header">
        {category && (
          <span class="blog-category">{category}</span>
        )}

        <h1>{title}</h1>

        <div class="blog-meta">
          {publishDate && (
            <time datetime={publishDate.toISOString()}>
              Published: {publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          )}

          {updatedDate && (
            <time datetime={updatedDate.toISOString()}>
              Updated: {updatedDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          )}
        </div>
      </header>

      <div class="blog-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0;
  }

  .blog-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .blog-category {
    display: inline-block;
    background: #e8d5c4;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .blog-header h1 {
    margin-bottom: 1rem;
    color: #2c2416;
  }

  .blog-meta {
    color: #777;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .blog-content {
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .blog-content h2,
  .blog-content h3 {
    margin-top: 2rem;
    color: #2c2416;
  }

  .blog-content p {
    margin-bottom: 1rem;
  }

  .blog-content ul {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
</style>